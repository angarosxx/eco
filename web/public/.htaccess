<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 🚀 1. EXCLUSIÓN TOTAL DE API
    RewriteCond %{REQUEST_URI} ^/api [NC]
    RewriteRule ^ - [L]

    # 📂 2. PERMITIR RECURSOS REALES
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 🔀 3. ENRUTADOR CENTRAL
    RewriteRule ^ index.php [L]
</IfModule>