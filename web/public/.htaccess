RewriteEngine On
RewriteBase /

# 🔥 FORCE EXCLUSION: If the request is for anything in the api folder, serve it directly
RewriteCond %{REQUEST_URI} ^/api/ [NC]
RewriteRule ^ - [L]

# Global fallback router for clean standard pages
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]